# NCN console OAuth/OIDC login credentials.
# Copy to /etc/ncn-core-console/oauth.env (chmod 600) and fill per provider.
# A provider with no client id/secret is gracefully DISABLED (its login button
# errors with "provider not configured"); other login methods are unaffected.
# systemd loads this via EnvironmentFile (ncn-api.service); `systemctl restart
# ncn-api` to apply.
#
# Register each OAuth app with redirect URI EXACTLY:
#   https://admin.example.com/api/v1/auth/oauth/<provider>/callback
# (must match NCN_OAUTH_REDIRECT_BASE below + the path, character-for-character).

# Base for the redirect URIs (default https://admin.example.com).
NCN_OAUTH_REDIRECT_BASE=https://admin.example.com

# (Google / Microsoft were dropped per ops decision — only GitHub + Telegram.)

# GitHub — github.com/settings/developers → OAuth Apps → New.
#   Authorization callback URL: https://admin.example.com/api/v1/auth/oauth/github/callback
NCN_OAUTH_GITHUB_CLIENT_ID=
NCN_OAUTH_GITHUB_CLIENT_SECRET=

# Telegram — NEW OIDC flow. In @BotFather switch the bot's login to "OpenID
# Connect Login", register the redirect URI EXACTLY:
#   https://admin.example.com/api/v1/auth/oauth/telegram/callback
# then paste the issued Client ID + Client Secret below. Enabled only when both
# are set; identity (Telegram user id) comes from the id_token. The old Login
# Widget (NCN_TG_BOT_USERNAME) is no longer used for web login.
NCN_OAUTH_TELEGRAM_CLIENT_ID=
NCN_OAUTH_TELEGRAM_CLIENT_SECRET=
# (legacy; harmless to leave set — no longer used for web login)
NCN_TG_BOT_USERNAME=

# DeepSeek (LLM) — powers the bot AI features (/ask · /summary · /chat · group
# companion · op-failure diagnosis) and the console /admin/assistant page.
# Key from platform.deepseek.com → API keys. Server-side only; never shipped to
# the frontend. Absent → all AI features gracefully disabled. Optional model
# override (default deepseek-chat; deepseek-reasoner for the R1 reasoning model).
NCN_DEEPSEEK_API_KEY=
NCN_DEEPSEEK_MODEL=deepseek-chat
