# /etc/ncn-lb/cf.env on the standby (0600). Secret — never commit the real one.
CF_API_TOKEN=cfat_xxx                 # Cloudflare token, Zone:DNS:Edit on the zone
CF_ZONE_ID=your-cf-zone-id
# space-separated recordid=newcontent pairs (A + AAAA → the standby's public IPs).
# MUST be quoted — the value has a space, else `. cf.env` runs the 2nd pair as a command.
CF_RECORDS="<A_record_id>=<standby_v4> <AAAA_record_id>=<standby_v6>"
CF_RECORD_NAME=admin.example.com
